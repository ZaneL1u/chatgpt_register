{
  "mode": "yolo",
  "depth": "standard",
  "model_profile": "quality",
  "commit_docs": true,
  "search_gitignored": false,
  "branching_strategy": "none",
  "phase_branch_template": "gsd/phase-{phase}-{slug}",
  "milestone_branch_template": "gsd/{milestone}-{slug}",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true
  },
  "parallelization": true,
  "brave_search": false,
  "language": {
    "default": "zh-CN",
    "strict": true,
    "applies_to": [
      "codex",
      "gsd",
      "subagents",
      "planning_docs",
      "reviews",
      "status_updates"
    ],
    "exceptions": [
      "code",
      "commands",
      "file_paths",
      "env_vars",
      "api_fields",
      "protocol_names",
      "logs",
      "third_party_identifiers"
    ]
  }
}
